{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Chonk — Fifty monorepo",
		"description": "Neo-brutalist WooCommerce variant of Obel. Chunky, high-contrast, opinionated."
	},
	"landingPage": "/",
	"login": true,
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"phpExtensionBundles": [
		"kitchen-sink"
	],
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "wordpress.org/plugins",
				"slug": "woocommerce"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "git:directory",
				"url": "https://github.com/RegionallyFamous/fifty",
				"ref": "main",
				"refType": "branch",
				"path": "chonk"
			},
			"options": {
				"activate": true,
				"targetFolderName": "chonk"
			}
		}
	]
}
